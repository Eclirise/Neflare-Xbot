[Unit]
Description=NeFlare Telegram bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/neflare/bot.env
WorkingDirectory=/usr/local/lib/neflare-bot
ExecStart=/usr/bin/python3 /usr/local/lib/neflare-bot/main.py
Restart=on-failure
RestartSec=5s
User=root
Group=root
UMask=0077
PrivateTmp=yes
ProtectHome=yes
ProtectSystem=full
NoNewPrivileges=yes

[Install]
WantedBy=multi-user.target
