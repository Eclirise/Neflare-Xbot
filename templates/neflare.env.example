# NeFlare runtime configuration example.
# Copy into /etc/neflare/neflare.env or pass via --config FILE.

UI_LANG=en
ADMIN_USER=admin
ADMIN_PUBLIC_KEY='ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... admin@example'
SSH_PORT=45222
ENABLE_IPV6=yes
ENABLE_DOCKER_TESTS=yes
ENABLE_TIME_SYNC=yes
ENABLE_BOT=yes
BOT_LOG_RETENTION_DAYS=14
BOT_LOG_MAX_BYTES=65536

REPO_SYNC_URL=https://github.com/Eclirise/Neflare-Xbot.git
REPO_SYNC_BRANCH=main
REPO_SYNC_DIR=/opt/Neflare-Xbot

XRAY_INSTALL_SCRIPT_URL=https://raw.githubusercontent.com/XTLS/Xray-install/e741a4f56d368afbb9e5be3361b40c4552d3710d/install-release.sh
XRAY_INSTALL_SCRIPT_SHA256=7f70c95f6b418da8b4f4883343d602964915e28748993870fd554383afdbe555
XRAY_INSTALL_VERIFY_SHA256=no

ENABLE_VLESS_REALITY=yes
ENABLE_HYSTERIA2=no
ENABLE_SS2022=no

XRAY_LISTEN_PORT=443
ALLOW_NONSTANDARD_REALITY_PORT=no
ALLOW_DISCOURAGED_REALITY_TARGET=no
REALITY_CANDIDATES=camouflage1.example.com,camouflage2.example.net
REALITY_AUTO_RECOMMEND=yes
REALITY_SELECTED_DOMAIN=
REALITY_SERVER_NAME=
REALITY_DEST=
XRAY_UUID=
XRAY_PRIVATE_KEY=
XRAY_PUBLIC_KEY=
XRAY_SHORT_IDS=

HYSTERIA2_VERSION=v2.8.1
HYSTERIA2_DOMAIN=hy2.example.com
HYSTERIA2_LISTEN_PORT=443
HYSTERIA2_TLS_MODE=acme
HYSTERIA2_ACME_EMAIL=admin@example.com
HYSTERIA2_ACME_DIR=/var/lib/neflare/hysteria2/acme
HYSTERIA2_ACME_CHALLENGE_TYPE=http
HYSTERIA2_ACME_HTTP_PORT=80
HYSTERIA2_TLS_CERT_FILE=
HYSTERIA2_TLS_KEY_FILE=
HYSTERIA2_AUTH_PASSWORD=
HYSTERIA2_MASQUERADE_TYPE=proxy
HYSTERIA2_MASQUERADE_URL=https://news.ycombinator.com/
HYSTERIA2_MASQUERADE_REWRITE_HOST=yes
HYSTERIA2_MASQUERADE_INSECURE=no

SS2022_LISTEN_PORT=40010
SS2022_METHOD=2022-blake3-aes-256-gcm
# SS2022 建议使用 openssl rand -base64 32 生成密钥，并保持系统时间同步。
SS2022_PASSWORD=

BOT_TOKEN=
CHAT_ID=
BOT_BIND_TOKEN=
REPORT_TIME=08:00
REPORT_TZ=Asia/Shanghai
QUOTA_MONTHLY_CAP_GB=0
QUOTA_RESET_DAY_UTC=1

SERVER_PUBLIC_ENDPOINT=
