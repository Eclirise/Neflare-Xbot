[Unit]
Description=NeFlare REALITY lint watcher
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/neflare/bot.env
WorkingDirectory=/usr/local/lib/neflare-bot
ExecStart=/usr/bin/python3 /usr/local/lib/neflare-bot/main.py --run-reality-lint-watch
User=root
Group=root
UMask=0077
PrivateTmp=yes
ProtectHome=yes
ProtectSystem=full
NoNewPrivileges=yes
