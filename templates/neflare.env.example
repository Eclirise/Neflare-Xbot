# NeFlare runtime configuration example.
# Copy into /etc/neflare/neflare.env or pass via --config FILE.

UI_LANG=en
ADMIN_USER=admin
ADMIN_PUBLIC_KEY='ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... admin@example'
SSH_PORT=45222
ENABLE_IPV6=yes
ENABLE_BOT=yes
ENABLE_DOCKER_TESTS=yes
BOT_LOG_RETENTION_DAYS=14
BOT_LOG_MAX_BYTES=65536
REPO_SYNC_URL=https://github.com/Eclirise/Neflare-Xbot.git
REPO_SYNC_BRANCH=main
REPO_SYNC_DIR=/opt/Neflare-Xbot
XRAY_INSTALL_SCRIPT_URL=https://raw.githubusercontent.com/XTLS/Xray-install/e741a4f56d368afbb9e5be3361b40c4552d3710d/install-release.sh
XRAY_INSTALL_SCRIPT_SHA256=7f70c95f6b418da8b4f4883343d602964915e28748993870fd554383afdbe555
XRAY_INSTALL_VERIFY_SHA256=no
XRAY_LISTEN_PORT=443
ALLOW_NONSTANDARD_REALITY_PORT=no
ALLOW_DISCOURAGED_REALITY_TARGET=no
BOT_TOKEN=
CHAT_ID=
BOT_BIND_TOKEN=
REPORT_TIME=08:00
REPORT_TZ=Asia/Shanghai
QUOTA_MONTHLY_CAP_GB=0
QUOTA_RESET_DAY_UTC=1
REALITY_CANDIDATES=camouflage1.example.com,camouflage2.example.net
REALITY_AUTO_RECOMMEND=yes
SERVER_PUBLIC_ENDPOINT=
